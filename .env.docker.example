# ===== DATABASE =====
DB_NAME=marketplace_db
DB_USER=postgres
DB_PASS=postgres
DB_HOST=db
DB_PORT=5432

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ===== JWT =====
SECRET_KEY=your-secret-key-min-32-characters-long!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== REDIS =====
REDIS_URL=redis://redis:6379/0
ENABLE_CACHE=false

# ===== APP =====
APP_NAME=Marketplace API
APP_VERSION=1.0.0
API_PREFIX=/api/v1
ENV=development
DEBUG=true

HOST=0.0.0.0
PORT=8000
WORKERS=1

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true

LOG_LEVEL=DEBUG
SLOW_REQUEST_THRESHOLD=1.0

RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json

# ===== STATIC =====
STATIC_DIR=/app/static
IMAGES_DIR=/app/static/images/products
MAX_IMAGE_SIZE_MB=10
WEBP_QUALITY=85

# ===== SEARCH =====
SEARCH_MIN_LENGTH=3
SEARCH_MAX_LENGTH=255

# ===== PAGINATION =====
DEFAULT_LIMIT=10
MAX_LIMIT=100

# ===== LOCALIZATION =====
DEFAULT_LANG=ru
SUPPORTED_LANGS=ru,en,kk